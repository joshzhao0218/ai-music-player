# Environment Configuration Template

# Qwen AI API Key (Get from https://dashscope.console.aliyun.com/)
QWEN_API_KEY=your-api-key-here

# Server Configuration
SERVER_PORT=8080

# JVM Options
JAVA_OPTS=-Xmx512m -Xms256m

# Logging
LOG_LEVEL=INFO

# Music Source (local, spotify, apple-music)
MUSIC_SOURCE=local

# Default Volume (0-100)
DEFAULT_VOLUME=70
